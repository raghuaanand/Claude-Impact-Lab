generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  MANAGEMENT
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String?   @unique
  emailVerified  DateTime?
  mobile         String?   @unique
  mobileVerified DateTime?
  password       String?
  image          String?
  role           Role      @default(USER)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  otpCodes OtpCode[]

  missingReports   MissingReport[]
  foundReports     FoundReport[]
  suggestedMatches MatchSuggestion[] @relation("SuggestedMatches")
  reviewedMatches   MatchSuggestion[] @relation("ReviewedMatches")
  auditLogs        AuditLog[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model OtpCode {
  id        String   @id @default(cuid())
  mobile    String
  code      String
  purpose   String   @default("login")
  expiresAt DateTime
  createdAt DateTime @default(now())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([mobile, purpose])
}

enum ReportStatus {
  OPEN
  INVESTIGATING
  RESOLVED
  CLOSED
}

enum Gender {
  MALE
  FEMALE
  OTHER
  UNKNOWN
}

enum MatchStatus {
  PENDING
  CONFIRMED
  REJECTED
}

enum AuditAction {
  CREATED
  UPDATED
  DELETED
  STATUS_CHANGED
  MATCH_SUGGESTED
  MATCH_CONFIRMED
  MATCH_REJECTED
}

enum EntityType {
  MISSING_REPORT
  FOUND_REPORT
  MATCH_SUGGESTION
}

model Location {
  id         String   @id @default(cuid())
  latitude   Float?
  longitude  Float?
  address    String?
  city       String?
  state      String?
  country    String?
  postalCode String?
  createdAt  DateTime @default(now())

  missingReports MissingReport[]
  foundReports   FoundReport[]

  @@index([latitude, longitude])
  @@index([city, state, country])
}

model MissingReport {
  id           String       @id @default(cuid())
  reporterId   String
  reporter     User         @relation(fields: [reporterId], references: [id])
  personName   String
  age          Int?
  gender       Gender       @default(UNKNOWN)
  description  String?
  lastSeenAt   DateTime?
  locationId   String?
  location     Location?    @relation(fields: [locationId], references: [id], onDelete: SetNull)
  status       ReportStatus @default(OPEN)
  contactName  String?
  contactPhone String?
  contactEmail String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  images           ReportImage[]
  audio            ReportAudio[]
  matchSuggestions MatchSuggestion[]
  auditLogs        AuditLog[]

  @@index([status])
  @@index([reporterId])
  @@index([locationId])
  @@index([lastSeenAt])
  @@index([personName])
}

model FoundReport {
  id           String       @id @default(cuid())
  reporterId   String
  reporter     User         @relation(fields: [reporterId], references: [id])
  age          Int?
  gender       Gender       @default(UNKNOWN)
  description  String?
  foundAt      DateTime?
  locationId   String?
  location     Location?    @relation(fields: [locationId], references: [id], onDelete: SetNull)
  status       ReportStatus @default(OPEN)
  contactName  String?
  contactPhone String?
  contactEmail String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  images           ReportImage[]
  audio            ReportAudio[]
  matchSuggestions MatchSuggestion[]
  auditLogs        AuditLog[]

  @@index([status])
  @@index([reporterId])
  @@index([locationId])
  @@index([foundAt])
}

model ReportImage {
  id              String         @id @default(cuid())
  url             String
  missingReportId String?
  missingReport   MissingReport? @relation(fields: [missingReportId], references: [id], onDelete: Cascade)
  foundReportId   String?
  foundReport     FoundReport?   @relation(fields: [foundReportId], references: [id], onDelete: Cascade)
  createdAt       DateTime       @default(now())

  @@index([missingReportId])
  @@index([foundReportId])
}

model ReportAudio {
  id              String         @id @default(cuid())
  url             String
  durationSeconds Int?
  missingReportId String?
  missingReport   MissingReport? @relation(fields: [missingReportId], references: [id], onDelete: Cascade)
  foundReportId   String?
  foundReport     FoundReport?   @relation(fields: [foundReportId], references: [id], onDelete: Cascade)
  createdAt       DateTime       @default(now())

  @@index([missingReportId])
  @@index([foundReportId])
}

model MatchSuggestion {
  id              String      @id @default(cuid())
  missingReportId String
  foundReportId   String
  missingReport   MissingReport @relation(fields: [missingReportId], references: [id])
  foundReport     FoundReport   @relation(fields: [foundReportId], references: [id])
  score           Float?
  status          MatchStatus @default(PENDING)
  suggestedById   String?
  suggestedBy     User?       @relation("SuggestedMatches", fields: [suggestedById], references: [id], onDelete: SetNull)
  reviewedById    String?
  reviewedBy      User?       @relation("ReviewedMatches", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt      DateTime?
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@unique([missingReportId, foundReportId])
  @@index([status])
  @@index([missingReportId])
  @@index([foundReportId])
  @@index([suggestedById])
}

model AuditLog {
  id              String         @id @default(cuid())
  userId          String?
  user            User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  action          AuditAction
  entityType      EntityType
  entityId        String
  missingReportId String?
  missingReport   MissingReport? @relation(fields: [missingReportId], references: [id], onDelete: SetNull)
  foundReportId   String?
  foundReport     FoundReport?   @relation(fields: [foundReportId], references: [id], onDelete: SetNull)
  metadata        Json?
  createdAt       DateTime       @default(now())

  @@index([userId])
  @@index([entityType, entityId])
  @@index([missingReportId])
  @@index([foundReportId])
  @@index([createdAt])
}


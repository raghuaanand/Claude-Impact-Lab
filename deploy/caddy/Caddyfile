# KHUMMELA — Caddy automatic HTTPS (alternative to Nginx + Certbot)
#
# Install Caddy on Ubuntu, then:
#   sudo cp deploy/caddy/Caddyfile /etc/caddy/Caddyfile
#   sudo sed -i 's/YOUR_DOMAIN/yourdomain.com/g' /etc/caddy/Caddyfile
#   sudo systemctl reload caddy
#
# Stop Nginx if you use Caddy: sudo systemctl stop nginx

YOUR_DOMAIN, www.YOUR_DOMAIN {
    reverse_proxy localhost:3000

    header {
        X-Frame-Options "SAMEORIGIN"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
    }
}
